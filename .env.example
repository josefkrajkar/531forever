# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local — it contains secrets.

NEXT_PUBLIC_CONVEX_URL=your-convex-url-here
NEXT_PUBLIC_CONVEX_DEPLOY_NAME=your-deploy-name-here
CONVEX_DEPLOY_KEY=your-convex-deploy-key-here
SITE_URL=your-site-url-here

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=your-convex-deployment-here

NEXT_PUBLIC_CONVEX_SITE_URL=your-convex-site-url-here

# The following variables are set in Convex dashboard (Settings → Environment Variables),
# NOT in .env.local. They are listed here for documentation purposes only.
#
# OTP_ENDPOINT=your-otp-relay-endpoint-here
# CHAT_ID=your-chat-id-here
# SECRET_KEY=your-random-secret-here
# APP_NAME=Silový deník
